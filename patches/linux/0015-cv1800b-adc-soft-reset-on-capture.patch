cv1800b-sound-adc: soft-reset ADC на старте захвата (детерминированный старт)

Симптом: микрофон стартовал недетерминированно (то тишина, то чисто, то
railing/MAX) при одном и том же gain. Причина: mainline-драйвер не
сбрасывал внутренний ADC между захватами, сигма-дельта/CIC поднимался в
случайном накопленном состоянии. Vendor (cv181xadc) на каждом shutdown
делает cv182xa_reset_adc(), а в prepare перезаписывает ANA0/ANA2.

В hw_params: soft-reset ADC (active-low импульс на бите 29 регистра
0x03003008, как vendor) + re-commit ANA2/ANA0 после сброса. Проверено на
железе: 4 записи подряд на одном gain дают стабильный уровень (раньше
прыгало тишина/MAX). dev_dbg с дампом регистров оставлен для диагностики.

Применение:
    git -C src/linux apply patches/linux/0015-cv1800b-adc-soft-reset-on-capture.patch
--- a/sound/soc/sophgo/cv1800b-sound-adc.c
+++ b/sound/soc/sophgo/cv1800b-sound-adc.c
@@ -95,10 +95,14 @@
 
 struct cv1800b_priv {
 	void __iomem *regs;
+	void __iomem *rst;	/* audio soft-reset reg 0x03003008 (ADC = bit 29) */
 	struct device *dev;
 	unsigned int mclk_rate;
 };
 
+/* 0x03003008 bit 29 (active-low) is the internal-ADC soft reset (vendor). */
+#define CV1800B_ADC_RESET_BIT          BIT(29)
+
 static int cv1800b_adc_setbclk_div(struct cv1800b_priv *priv, unsigned int rate)
 {
 	u32 val;
@@ -178,9 +182,32 @@
 {
 	struct cv1800b_priv *priv = snd_soc_dai_get_drvdata(dai);
 	unsigned int rate = params_rate(params);
-	u32 val;
+	u32 val, r;
 	int ret;
 
+	dev_dbg(priv->dev,
+		 "adc hw_params IN: CTRL0=%#x CTRL1=%#x ANA0=%#x ANA3=%#x\n",
+		 readl(priv->regs + CV1800B_RXADC_CTRL0),
+		 readl(priv->regs + CV1800B_RXADCC_CTRL1),
+		 readl(priv->regs + CV1800B_RXADC_ANA0),
+		 readl(priv->regs + CV1800B_RXADC_ANA3));
+
+	/*
+	 * Soft-reset the internal ADC so each capture starts from a known
+	 * state (vendor cv182xa_reset_adc). Without it the sigma-delta/CIC
+	 * comes up in a random state (silence / clean / railing) per open.
+	 * Active-low pulse on bit 29 of the shared audio reset register.
+	 */
+	r = readl(priv->rst);
+	writel(r & ~CV1800B_ADC_RESET_BIT, priv->rst);
+	writel(r | CV1800B_ADC_RESET_BIT, priv->rst);
+
+	/* Re-commit analog regs after reset (vendor rewrites ANA0/ANA2). */
+	writel(readl(priv->regs + CV1800B_RXADC_ANA2),
+	       priv->regs + CV1800B_RXADC_ANA2);
+	writel(readl(priv->regs + CV1800B_RXADC_ANA0),
+	       priv->regs + CV1800B_RXADC_ANA0);
+
 	ret = cv1800b_adc_setbclk_div(priv, rate);
 	if (ret) {
 		dev_err(priv->dev,
@@ -193,6 +220,13 @@
 	val = u32_replace_bits(val, 1, REG_RXADC_IGR_INIT);
 	val = u32_replace_bits(val, DECIMATION_64, REG_RXADC_CIC_OPT);
 	writel(val, priv->regs + CV1800B_RXADCC_CTRL1);
+
+	dev_dbg(priv->dev,
+		 "adc hw_params OUT: CTRL0=%#x CTRL1=%#x ANA0=%#x ANA3=%#x\n",
+		 readl(priv->regs + CV1800B_RXADC_CTRL0),
+		 readl(priv->regs + CV1800B_RXADCC_CTRL1),
+		 readl(priv->regs + CV1800B_RXADC_ANA0),
+		 readl(priv->regs + CV1800B_RXADC_ANA3));
 	return 0;
 }
 
@@ -308,6 +342,11 @@
 	if (IS_ERR(priv->regs))
 		return PTR_ERR(priv->regs);
 
+	/* Audio soft-reset register (shared sysctrl), vendor uses 0x03003008. */
+	priv->rst = devm_ioremap(dev, 0x03003008, 4);
+	if (!priv->rst)
+		return -ENOMEM;
+
 	platform_set_drvdata(pdev, priv);
 	return devm_snd_soc_register_component(&pdev->dev,
 					       &cv1800b_adc_component,
