+++ b/arch/riscv/boot/dts/sophgo/sg2002-licheerv-nano-e.dts	2026-05-26 18:45:03.293229878 +0300
@@ -28,6 +28,8 @@
 		serial2 = &uart2;
 		serial3 = &uart3;
 		serial4 = &uart4;
+		i2c1 = &i2c1;
+		i2c3 = &i2c3;
 		ethernet0 = &gmac0;
 	};
 
@@ -149,3 +151,11 @@
 &saradc {
 	status = "okay";
 };
+
+&i2c1 {
+	status = "okay";
+};
