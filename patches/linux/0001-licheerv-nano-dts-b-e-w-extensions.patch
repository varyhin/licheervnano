+// SPDX-License-Identifier: (GPL-2.0 OR MIT)
+/*
+ * LicheeRV Nano E (Ethernet variant)
+ *
+ * Based on sg2002-licheerv-nano-b.dts by Thomas Bonnefille.
+ * Difference vs B: on-board RJ45 wired to SG2002 internal MAC + internal PHY,
+ * so we enable gmac0 (otherwise identical hardware).
+ */
+
+/dts-v1/;
+
