+	/*
+	 * Drive BLK_MASTER_MODE and the forced BCLK output together. As a clock
+	 * consumer (slave) the controller must NOT generate BCLK/LRCK: the
+	 * internal ADC is a clock-master-only codec and the single clock source,
+	 * so a controller that also forced BCLK out would race it, and the RX
+	 * deserializer would latch the ADC frame at a random bit offset (level
+	 * x2^k) and a random L/R slot per open. BCLK_OUT_FORCE_EN resets to 1, so
+	 * clearing only BLK_MASTER_MODE is not enough; it must be cleared too.
+	 * MCLK to the codec is still provided separately via set_sysclk/mclk-fs.
+	 */
 	val = readl(i2s->base + CV1800B_BLK_MODE_SETTING);
 	val = u32_replace_bits(val, master, BLK_MASTER_MODE_MASK);
 	writel(val, i2s->base + CV1800B_BLK_MODE_SETTING);
+
+	val = readl(i2s->base + CV1800B_CLK_CTRL0);
+	val = u32_replace_bits(val, master, CLK_BCLK_OUT_CLK_FORCE_EN_MASK);
+	writel(val, i2s->base + CV1800B_CLK_CTRL0);
+
+	dev_info(i2s->dev, "clock %s\n", master ? "master" : "slave");
 	return 0;
 }
 
