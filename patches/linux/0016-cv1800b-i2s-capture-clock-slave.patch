-		cv1800b_adc_enable(priv, false);
-		break;
-	default:
-		return -EINVAL;
-	}
+	/*
+	 * Power the ADC and start its I2S-TX here, in prepare, while the audio
+	 * clock is already running (the cpu DAI enables it in hw_params) and
+	 * BEFORE the controller enables its I2S RX at trigger. As the I2S clock
+	 * master the ADC must be generating BCLK/LRCK before the RX (a slave)
+	 * latches onto them. The settle below trims the analog start-up transient.
+	 */
+	cv1800b_adc_enable(priv, true);
+	dev_dbg(priv->dev, "adc enabled, ctrl0=0x%08x\n",
+		readl(priv->regs + CV1800B_RXADC_CTRL0));
 
+	/*
+	 * Settle the analog side before the I2S RX latches at trigger. The
+	 * floating right input has an exponential DC-settling transient after
+	 * enable (measured on hw: peak ~31000 at t=0, tau ~70 ms, down to the
+	 * noise floor by ~700 ms). The left input (the mic) settles at once, but
+	 * mono capture via plughw downmixes L+R, so without this the first ~0.5 s
+	 * of a recording carries a loud transient from the right channel. 1000 ms
+	 * is ~700 ms measured plus margin for unit/temperature spread in tau;
+	 * capture is opened manually (no boot autostart), so the latency is fine.
+	 * This wait is analog-only; vendor has no settle, kept as a measured margin.
+	 * No SDM-init (vendor-faithful: no RSTSDM/VCMT/DITHER); the per-open soft
+	 * reset in hw_params gives the modulator a clean start.
+	 */
+	msleep(1000);
 	return 0;
 }
 
+static void cv1800b_adc_shutdown(struct snd_pcm_substream *substream,
+				 struct snd_soc_dai *dai)
+{
+	struct cv1800b_priv *priv = snd_soc_dai_get_drvdata(dai);
+
+	/*
+	 * Power the ADC down on close so the next capture re-runs the soft reset
+	 * (hw_params) and enable+settle (prepare) from a clean off state. Enable
+	 * lives in prepare and the I2S RX/DMA is owned by the cpu DAI, so the
+	 * codec needs no trigger op.
+	 */
+	cv1800b_adc_enable(priv, false);
+	dev_dbg(priv->dev, "adc off (shutdown)\n");
+}
