+/* 25 MHz reference ticks per 32768 Hz period, nominal 762.9 */
+#define FC_COARSE_TARGET_LO    755
+#define FC_COARSE_TARGET_HI    770
+#define FC_FINE_PERIODS        256
+#define FC_REF_HZ              25000000
+#define ANA_CALIB_INIT         0x10100
+#define ANA_CALIB_INIT_STEP    128
