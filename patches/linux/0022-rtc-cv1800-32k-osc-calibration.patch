+/*
+ * The frequency calibration counters compare the 32K oscillator with
+ * the 25 MHz reference clock. The high half of each CAL register is a
+ * measurement counter, a change there means the low half holds a fresh
+ * measurement.
+ */
+static int cv1800_rtc_fc_measure(struct cv1800_rtc_priv *info, u32 reg,
+				 u32 marker_shift, u32 mask, u32 *result)
+{
+	u32 prev, val;
+	int ret;
+
+	regmap_read(info->rtc_map, reg, &prev);
+	ret = regmap_read_poll_timeout(info->rtc_map, reg, val,
+				       (val >> marker_shift) !=
+				       (prev >> marker_shift),
+				       100, 500000);
+	if (ret)
+		return ret;
+
+	usleep_range(400, 500);
+	regmap_read(info->rtc_map, reg, &val);
+	*result = val & mask;
+
+	return 0;
+}
+
+static int cv1800_rtc_calib_coarse(struct cv1800_rtc_priv *info)
+{
+	u32 step = ANA_CALIB_INIT_STEP;
+	u32 trim, cycles;
+	int ret = 0;
+
+	regmap_write(info->rtc_map, ANA_CALIB, ANA_CALIB_INIT);
+	usleep_range(200, 300);
+	regmap_read(info->rtc_map, ANA_CALIB, &trim);
+
+	regmap_write(info->rtc_map, FC_COARSE_EN, 1);
+
+	while (1) {
+		ret = cv1800_rtc_fc_measure(info, FC_COARSE_CAL, 16,
+					    FC_COARSE_MASK, &cycles);
+		if (ret)
+			break;
+
+		if (cycles >= FC_COARSE_TARGET_LO &&
+		    cycles <= FC_COARSE_TARGET_HI)
+			break;
+
+		if (!step) {
+			ret = -ERANGE;
+			break;
+		}
+
+		if (cycles > FC_COARSE_TARGET_HI)
+			trim += step;
+		else
+			trim -= step;
+		step >>= 1;
+
+		regmap_write(info->rtc_map, ANA_CALIB, trim);
+	}
+
+	regmap_write(info->rtc_map, FC_COARSE_EN, 0);
+
+	return ret;
+}
+
+static int cv1800_rtc_calib_fine(struct device *dev,
+				 struct cv1800_rtc_priv *info)
+{
+	u32 cycles;
+	u64 freq;
+	int ret;
+
+	regmap_write(info->rtc_map, FC_FINE_EN, 1);
+	ret = cv1800_rtc_fc_measure(info, FC_FINE_CAL, 24, FC_FINE_MASK,
+				    &cycles);
+	regmap_write(info->rtc_map, FC_FINE_EN, 0);
+
+	if (ret)
+		return ret;
+	if (!cycles)
+		return -EINVAL;
+
+	/*
+	 * cycles is the length of FC_FINE_PERIODS oscillator periods in
+	 * 25 MHz reference ticks. The seconds divider takes the actual
+	 * oscillator frequency in Hz as a 16.8 fixed point value.
+	 */
+	freq = div_u64((u64)FC_FINE_PERIODS * FC_REF_HZ * 256, cycles);
+
+	regmap_update_bits(info->rtc_map, SEC_PULSE_GEN, SEC_PULSE_GEN_DIV,
+			   (u32)freq);
+
+	dev_info(dev, "32k osc calibrated to %llu.%02llu Hz\n", freq >> 8,
+		 ((freq & 0xFF) * 100) >> 8);
+
+	return 0;
+}
+
+static void cv1800_rtc_calibrate(struct device *dev,
+				 struct cv1800_rtc_priv *info)
+{
+	u32 ctrl, pulse;
+	int ret;
+
+	regmap_read(info->rtc_map, CTRL0, &ctrl);
+	if (ctrl & RTC_MODE_XTAL32K)
+		return;
+
+	/*
+	 * Trim and divider writes only take effect while the rtc_sys
+	 * side generator is selected. Restore the selection afterwards
+	 * so probing does not flip the RTC enabled state.
+	 */
+	regmap_read(info->rtc_map, SEC_PULSE_GEN, &pulse);
+	regmap_update_bits(info->rtc_map, SEC_PULSE_GEN, SEL_SEC_PULSE, 0);
+
+	ret = cv1800_rtc_calib_coarse(info);
+	if (!ret)
+		ret = cv1800_rtc_calib_fine(dev, info);
+	if (ret)
+		dev_warn(dev, "32k osc calibration failed (%d)\n", ret);
+
+	regmap_update_bits(info->rtc_map, SEC_PULSE_GEN, SEL_SEC_PULSE,
+			   pulse & SEL_SEC_PULSE);
+}
+
 static int cv1800_rtc_probe(struct platform_device *pdev)
 {
 	struct cv1800_rtc_priv *rtc;
@@ -180,6 +331,8 @@
 
 	platform_set_drvdata(pdev, rtc);
 
+	cv1800_rtc_calibrate(&pdev->dev, rtc);
+
 	device_init_wakeup(&pdev->dev, 1);
 
 	rtc->rtc_dev = devm_rtc_allocate_device(&pdev->dev);
