diff -urN a/aic8800_fdrv/aic_kernel_compat.h b/aic8800_fdrv/aic_kernel_compat.h
--- a/aic8800_fdrv/aic_kernel_compat.h	1970-01-01 03:00:00.000000000 +0300
+++ b/aic8800_fdrv/aic_kernel_compat.h	2026-05-25 17:38:13.902586831 +0300
@@ -0,0 +1,61 @@
+/* SPDX-License-Identifier: GPL-2.0-or-later */
+/*
+ * Compatibility shims для сборки vendor AIC8800 driver под kernel 6.18.
+ * Vendor source написан под 5.10, в новых ядрах часть API переименована
+ * или удалена. Эти макросы перебрасывают старые имена на новые без
+ * необходимости править каждый вызов в десятках файлов.
+ *
+ * Подключается через ccflags-y += -include $(M)/aic_kernel_compat.h
+ * в Makefile.
+ */
+
+#ifndef AIC_KERNEL_COMPAT_H
+#define AIC_KERNEL_COMPAT_H
+
+#include <linux/version.h>
+
+/* del_timer и del_timer_sync удалены в 6.10:
+ *   "treewide: clean up del_timer/del_timer_sync occurrences"
+ * Заменены на timer_delete и timer_delete_sync.
+ */
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 10, 0)
+#ifndef del_timer
+#define del_timer(t)		timer_delete(t)
+#endif
+#ifndef del_timer_sync
+#define del_timer_sync(t)	timer_delete_sync(t)
+#endif
+#endif
+
+/* from_timer переименован в timer_container_of в 6.16:
+ *   "treewide: switch from from_timer to timer_container_of"
+ */
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 16, 0)
+#ifndef from_timer
+#define from_timer(var, callback_timer, timer_fieldname) \
+	timer_container_of(var, callback_timer, timer_fieldname)
+#endif
+#endif
+
+/* wakeup_source_create/add/remove/destroy удалены в 6.0+,
+ * заменены на wakeup_source_register/unregister, которые
+ * принимают struct device аргументом. Для большинства
+ * вызовов в этом driver устройство не передаётся (NULL),
+ * поэтому шим wrap'ит register с NULL.
+ */
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 0, 0)
+#ifndef wakeup_source_create
+#define wakeup_source_create(name)	wakeup_source_register(NULL, (name))
+#endif
+#ifndef wakeup_source_add
+#define wakeup_source_add(ws)		do { (void)(ws); } while (0)
+#endif
+#ifndef wakeup_source_remove
+#define wakeup_source_remove(ws)	do { (void)(ws); } while (0)
+#endif
+#ifndef wakeup_source_destroy
+#define wakeup_source_destroy(ws)	wakeup_source_unregister(ws)
+#endif
+#endif
+
+#endif /* AIC_KERNEL_COMPAT_H */
