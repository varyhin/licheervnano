+/*
+ * forward-port mainline: вернуть физ. адрес dmabuf по fd. Нужно
+ * dma-heap аллокатору рантайма: userspace не достаёт физадрес CMA-буфера
+ * через /proc/self/pagemap (mmap dma-heap это спец-отображение, pagemap
+ * не транслирует). Делаем то же, что prepare_buffer: attach + map +
+ * sg_dma_address.
+ */
+static int cvi_tpu_get_paddr(struct cvi_tpu_device *ndev, unsigned long arg)
+{
+	struct cvi_dmabuf_paddr_arg a;
+	struct dma_buf *dma_buf;
+	struct dma_buf_attachment *attachment;
+	struct sg_table *sgt;
+	int ret = 0;
+
+	if (copy_from_user(&a, (struct cvi_dmabuf_paddr_arg __user *)arg, sizeof(a)))
+		return -EFAULT;
+
+	dma_buf = dma_buf_get(a.fd);
+	if (IS_ERR(dma_buf))
+		return -EINVAL;
+
+	attachment = dma_buf_attach(dma_buf, ndev->dev);
+	if (IS_ERR(attachment)) {
+		ret = -EINVAL;
+		goto err_attach;
+	}
+
+	sgt = dma_buf_map_attachment_unlocked(attachment, DMA_BIDIRECTIONAL);
+	if (IS_ERR(sgt)) {
+		ret = -EINVAL;
+		goto err_map;
+	}
+
+	if (sgt->nents != 1) {
+		pr_err("get_paddr: dmabuf not contiguous (nents=%u)\n", sgt->nents);
+		ret = -EINVAL;
+		goto err_addr;
+	}
+	a.paddr = sg_dma_address(sgt->sgl);
+
+	if (copy_to_user((struct cvi_dmabuf_paddr_arg __user *)arg, &a, sizeof(a)))
+		ret = -EFAULT;
+
+err_addr:
+	dma_buf_unmap_attachment_unlocked(attachment, sgt, DMA_BIDIRECTIONAL);
+err_map:
+	dma_buf_detach(dma_buf, attachment);
+err_attach:
+	dma_buf_put(dma_buf);
+	return ret;
+}
