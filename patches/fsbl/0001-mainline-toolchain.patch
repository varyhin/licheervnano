--- a/fsbl/lib/cpu/riscv/bl2_entrypoint.S
+++ b/fsbl/lib/cpu/riscv/bl2_entrypoint.S
@@ -2,6 +2,12 @@
 #include "csr.h"
 #include <riscv/asm_macros.S>
 
+  # T-Head custom CSRs (vendor names → numeric values)
+  .equ mxstatus, 0x7c0
+  .equ mhcr,     0x7c1
+  .equ mcor,     0x7c2
+  .equ mhint,    0x7c5
+
   .option norvc
   .section .text.init,"ax",@progbits
   .globl bl2_entrypoint
--- a/fsbl/lib/cpu/riscv/cache.c
+++ b/fsbl/lib/cpu/riscv/cache.c
@@ -54,17 +54,18 @@
 	CACHE_OP_RANGE(DCACHE_CIPA_A0, start, size);
 }
 
+/* T-Head custom CSRs: mhcr = 0x7c1 */
 void enable_dcache(void)
 {
 	asm volatile(
-		"csrs mhcr, %0;" ::"rI"(0x2)
+		"csrs 0x7c1, %0;" ::"rI"(0x2)
 	);
 }
 
 void disable_dcache(void)
 {
 	asm volatile(
-		"csrc mhcr, %0;" ::"rI"(0x2)
+		"csrc 0x7c1, %0;" ::"rI"(0x2)
 	);
 }
 
