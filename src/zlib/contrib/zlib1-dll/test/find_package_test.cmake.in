cmake_minimum_required(VERSION 3.12...3.31)

project(
    zlib1-dll_find_package
    LANGUAGES C
    VERSION @zlib1-dll_VERSION@)

set(ZLIB1_DLL_SRCS
    @zlib1-dll_SOURCE_DIR@/../minizip/ioapi.c
    $<$<BOOL:${WIN32}>:@zlib1-dll_SOURCE_DIR@/../minizip/iowin32.c>
    @zlib1-dll_SOURCE_DIR@/../minizip/minizip.c
    @zlib1-dll_SOURCE_DIR@/../minizip/zip.c)

find_package(ZLIB1DLL
             @zlib1-dll_VERSION@
             CONFIG
             REQUIRED)

add_executable(test_example ${ZLIB1_DLL_SRCS})
target_link_libraries(test_example ZLIB1DLL::ZLIB1DLL)

add_executable(test_example_wapi ${ZLIB1_DLL_SRCS})
target_link_libraries(test_example_wapi ZLIB1DLL::ZLIBWAPI)
