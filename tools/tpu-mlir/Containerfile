# Воспроизводимая среда компилятора tpu-mlir (cv181x/SG2002).
#
# Зачем контейнер: wheel `tpu_mlir` это manylinux, рассчитан на старый glibc
# (~2.35) и Python 3.10. Наш хост Debian trixie это glibc 2.41 + Python 3.13,
# из-за чего прямой pip требует кучу костылей (standalone 3.10, вырезание
# бандленного glibc, yanked opencv, setuptools<80, ручные пины). ubuntu:22.04
# даёт ровно ту среду, что ждёт wheel, и все эти грабли исчезают.
#
# Сборка:   podman build -t tpu-mlir:local tools/tpu-mlir
# Запуск:   tools/tpu-mlir/run.sh model_transform.py ...
#           tools/tpu-mlir/run.sh model_deploy.py --chip cv181x ...
#
# tpu-mlir master эмитит cvimodel v1.4, что совпадает с нашим riscv64-рантаймом
# (cviruntime/cvikernel/cvibuilder из master). Менять версию не нужно.

FROM docker.io/library/ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# python3 в 22.04 это 3.10, glibc 2.35 это бандленный glibc wheel не конфликтует.
# libgl1 + libglib2.0-0 нужны opencv (cv2), ca-certificates для pip https.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 python3-pip python3-dev build-essential \
        libgl1 libglib2.0-0 ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Ставим onnx-вариант (protobuf==3.20.3 тянется сам). psutil незадекларирован
# в метаданных, но нужен mlir_shell.py. setuptools<80 ставим ПОСЛЕ, чтобы
# вернуть pkg_resources (в 81+ удалён), не дав tpu_mlir перебить его новым.
# yanked opencv-python-headless==4.8.0.74 обычный pip принимает (warning).
# pycocotools==2.0.6 (зависимость tpu_mlir) это sdist, компилируется и требует
# numpy+cython на этапе сборки. Ставим их и pycocotools отдельно с
# --no-build-isolation, иначе build-изоляция не видит numpy и падает.
# torch нужен даже для ONNX-пути (OnnxOpt.py импортит его безусловно), хотя
# в метаданных он только в extra [torch]. Ставим CPU-сборку с pytorch-индекса
# (лёгкая, без CUDA ~200МБ вместо ~2ГБ).
RUN python3 -m pip install --no-cache-dir --upgrade pip && \
    python3 -m pip install --no-cache-dir numpy==1.24.3 cython && \
    python3 -m pip install --no-cache-dir --no-build-isolation pycocotools==2.0.6 && \
    python3 -m pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cpu \
        torch==2.1.0 torchvision==0.16.0 && \
    python3 -m pip install --no-cache-dir 'tpu_mlir[onnx]' psutil && \
    python3 -m pip install --no-cache-dir 'setuptools<80'

WORKDIR /work
